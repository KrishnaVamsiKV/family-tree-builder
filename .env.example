# Copy to .env.local for local dev, and set the same vars in Vercel Project Settings.

# Secret used to sign session JWTs. Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# Vercel Postgres (added automatically when you create a Postgres store in Vercel,
# or pull with `vercel env pull .env.local`). @vercel/postgres reads POSTGRES_URL.
POSTGRES_URL=

# Vercel Blob token for photo storage (added automatically when you create a Blob
# store in Vercel). Needed by @vercel/blob.
BLOB_READ_WRITE_TOKEN=
